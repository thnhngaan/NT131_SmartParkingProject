<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Smart Parking</title>

  <!-- 🌐 FONT XỊN -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

  <!-- 🎨 TAILWIND -->
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">

  <style>
    body {
      font-family: 'Poppins', sans-serif;
    }
  </style>
</head>

<body class="bg-gradient-to-br from-indigo-100 via-purple-100 to-pink-100 min-h-screen flex justify-center pt-32">

  <div class="text-center">

  <img src="/images/logo_mmt-nth.png"
       alt="logo"
       class="mx-auto w-32 mb-4">

    <!-- 🚗 TITLE -->
    <h1 class="text-6xl font-bold text-gray-800 tracking-tight">
      Smart Parking
    </h1>

    <!-- 👋 SUB -->
    <p class="mt-5 text-xl text-gray-600 font-medium">
      Hello! Welcome to Smart Parking
    </p>

    <!-- ✨ DESC -->
    <p class="mt-2 text-gray-500">
      A project from group 4 - NT131
    </p>

    <!-- 🔘 BUTTON -->
    <div class="mt-10 flex justify-center gap-6">

      <!-- SIGN IN -->
      <a href="/login"
        class="px-8 py-3 text-white font-semibold rounded-xl
        bg-gradient-to-r from-blue-500 to-indigo-500
        shadow-lg hover:shadow-xl
        transform hover:-translate-y-1 hover:scale-105
        transition duration-300">
        Sign In
      </a>

      <!-- SIGN UP -->
      <a href="/signup"
      class="px-8 py-3 text-white font-semibold rounded-xl
      bg-gradient-to-r from-purple-500 to-indigo-600
      shadow-lg hover:shadow-xl
      transform hover:-translate-y-1 hover:scale-105
      transition duration-300">
        Sign Up
      </a>

    </div>

  </div>

</body>
</html>