<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Smart Parking Dashboard</title>

  <!-- FONT -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- TAILWIND -->
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">

  <style>
    body {
      font-family: 'Poppins', sans-serif;
    }
  </style>
</head>

<body class="bg-gradient-to-br from-indigo-100 via-purple-100 to-pink-100 h-screen overflow-hidden">
  <div class="h-screen p-4 md:p-6">
    <div class="h-full max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6">
      <aside class="md:col-span-3 lg:col-span-2 bg-white/80 backdrop-blur rounded-3xl shadow-xl border border-white/60 p-5 flex flex-col">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-800">Smart Parking</h2>
          <p class="text-xs text-gray-500 mt-1">Admin navigation</p>
        </div>
        <nav class="space-y-2">
          <button class="w-full text-left px-4 py-3 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-semibold shadow">
            Dashboard
          </button>
          <button class="w-full text-left px-4 py-3 rounded-xl text-gray-600 bg-gray-50 border border-gray-100 hover:bg-gray-100 transition">
            Analytics
          </button>
        </nav>
        <div class="mt-auto pt-4">
          <button onclick="logout()" class="w-full px-5 py-3 rounded-xl text-white font-semibold bg-gradient-to-r from-gray-800 to-gray-900 hover:from-gray-700 hover:to-black hover:shadow-lg transform hover:-translate-y-0.5 transition duration-300">
            Logout
          </button>
        </div>
      </aside>

      <main class="md:col-span-9 lg:col-span-10 bg-white rounded-3xl shadow-xl border border-white/60 p-6 md:p-8 h-full flex flex-col min-h-0">
        <div class="mb-6">
          <h1 class="text-3xl md:text-4xl font-bold text-gray-800">Smart Parking Dashboard</h1>
          <p id="greetingText" class="text-gray-500 mt-1">Hello, User</p>
        </div>

        <div id="analytics" class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6"></div>

        <div id="admin" class="mb-6 hidden">
          <form id="addSlotForm" class="bg-gradient-to-r from-indigo-50 to-purple-50 border border-indigo-100 p-5 rounded-2xl flex flex-col md:flex-row gap-3">
            <input type="text" id="slotNumber" placeholder="License Plate or Slot Number" class="p-3 rounded-xl border border-gray-200 w-full focus:outline-none focus:ring-2 focus:ring-indigo-400" required>
            <button class="bg-gradient-to-r from-indigo-500 to-purple-600 text-white px-6 py-3 rounded-xl font-semibold hover:shadow-lg transition duration-300">
              Add Entry
            </button>
          </form>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden flex-1 min-h-0">
          <div class="h-full overflow-y-auto">
            <table class="w-full">
              <thead class="bg-gray-50 text-gray-600 text-sm sticky top-0 z-10">
                <tr>
                  <th class="p-4 text-left">#</th>
                  <th class="p-4 text-left">Slot / Plate</th>
                  <th class="p-4 text-left">Status</th>
                  <th class="p-4 text-left">Date</th>
                  <th class="p-4 text-left">Time</th>
                  <th class="p-4 text-center">Action</th>
                </tr>
              </thead>
              <tbody id="slots" class="text-gray-700"></tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script>
    let user;
    const token = localStorage.getItem('token');
    if (!token) window.location.href = '/login';

    function formatDateTime(value) {
      if (!value) return 'N/A';
      return new Date(value).toLocaleString();
    }

    async function loadUser() {
      const res = await fetch('/api/auth/me', {
        headers: { 'Authorization': 'Bearer ' + token }
      });
      user = await res.json();
      const displayName = user.username || user.name || user.email || 'User';
      document.getElementById('greetingText').textContent = `Hello, ${displayName}`;
      if (user.role === 'admin') {
        document.getElementById('admin').classList.remove('hidden');
      }
    }

    async function loadAnalytics() {
      const res = await fetch('/api/parking/analytics', {
        headers: { 'Authorization': 'Bearer ' + token }
      });
      const data = await res.json();

      document.getElementById('analytics').innerHTML = `
        <div class="bg-gradient-to-r from-indigo-500 to-indigo-600 text-white p-6 rounded-2xl shadow-md">
          <p class="text-sm opacity-90">Total Capacity</p>
          <h2 class="text-3xl font-bold">${data.total}</h2>
        </div>

        <div class="bg-gradient-to-r from-indigo-500 to-indigo-600 text-white p-6 rounded-2xl shadow-md">
          <p class="text-sm opacity-90">Occupied</p>
          <h2 class="text-3xl font-bold">${data.occupied}</h2>
        </div>

        <div class="bg-gradient-to-r from-indigo-500 to-indigo-600 text-white p-6 rounded-2xl shadow-md">
          <p class="text-sm opacity-90">Available</p>
          <h2 class="text-3xl font-bold">${data.available}</h2>
        </div>
      `;
    }

    function formatDate(value) {
  if (!value) return 'N/A';
  return new Date(value).toLocaleDateString();
}

    function formatTime(value) {
  if (!value) return 'N/A';
  return new Date(value).toLocaleTimeString();
}
    async function loadSlots() {
      const res = await fetch('/api/parking', {
        headers: { 'Authorization': 'Bearer ' + token }
      });
      const slots = await res.json();

      const slotsDiv = document.getElementById('slots');

      slotsDiv.innerHTML = slots.map((slot, index) => `
        <tr class="border-b hover:bg-gray-50 transition">

          <td class="p-4">${index + 1}</td>

          <td class="p-4 font-semibold">${slot.slotNumber}</td>

          <td class="p-4">
            <span class="${(slot.status || 'Occupied') === 'Occupied' ? 'bg-rose-100 text-rose-600' : 'bg-emerald-100 text-emerald-600'} px-3 py-1 rounded-full text-sm">
              ${(slot.status || 'Occupied') === 'Occupied' ? 'Occupied' : 'Available'}
            </span>
          </td>

          <td class="p-4 text-gray-600">${formatDate(slot.entryTime)}</td>
<td class="p-4 text-gray-600">${formatTime(slot.entryTime)}</td>

          <td class="p-4 text-center">
            ${user && user.role === 'admin' ? `
              <button onclick="deleteSlot('${slot._id}')"
                class="bg-red-500 hover:bg-red-600 text-white px-4 py-1 rounded-lg">
                Delete  
              </button>
            ` : '<span class="text-gray-400 text-sm">-</span>'}
          </td>

        </tr>
      `).join('');
    }

    async function deleteSlot(id) {
      if (!confirm('Mark this car as exited and free the slot?')) return;

      const res = await fetch(`/api/parking/${id}`, {
        method: 'DELETE',
        headers: { 'Authorization': 'Bearer ' + token }
      });
      const data = await res.json();
      if (!res.ok) {
        alert(data.message || 'Unable to delete slot');
        return;
      }

      loadSlots();
      loadAnalytics();
    }

    document.getElementById('addSlotForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const slotNumber = document.getElementById('slotNumber').value.trim();

      const res = await fetch('/api/parking', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + token
        },
        body: JSON.stringify({ slotNumber })
      });
      const data = await res.json();
      if (!res.ok) {
        alert(data.message || 'Unable to add entry');
        return;
      }

      document.getElementById('slotNumber').value = '';

      loadSlots();
      loadAnalytics();
    });

    function logout() {
      localStorage.removeItem('token');
      window.location.href = '/';
    }

    loadUser().then(() => {
      loadAnalytics();
      loadSlots();
      setInterval(() => {
        loadSlots();
        loadAnalytics();
      }, 5000);
    });
  </script>

</body>
</html>