<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Verify Admin — Smart Parking</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <style>body { font-family: 'Poppins', sans-serif; }</style>
</head>
<body class="bg-gradient-to-br from-indigo-100 via-purple-100 to-pink-100 min-h-screen flex items-center justify-center p-4">
  <div class="bg-white p-10 rounded-3xl shadow-xl border border-gray-100 w-full max-w-md">
    <h1 class="text-2xl font-bold text-center text-gray-800 mb-2">Admin verification</h1>
    <p class="text-sm text-gray-500 text-center mb-6">
      Enter the PIN sent to the organization email to complete your admin registration.
    </p>
    <form id="verifyForm" class="space-y-4">
      <input type="email" id="email" placeholder="Your registration email" required
        class="w-full p-3 rounded-xl border focus:outline-none focus:ring-2 focus:ring-indigo-400">
      <input type="text" id="pin" placeholder="6-digit PIN" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required
        class="w-full p-3 rounded-xl border focus:outline-none focus:ring-2 focus:ring-indigo-400">
      <button type="submit"
        class="w-full py-3 rounded-xl text-white font-semibold bg-gradient-to-r from-indigo-500 to-purple-600 hover:shadow-lg transition duration-300">
        Verify &amp; create account
      </button>
    </form>
    <p class="text-center text-gray-500 mt-4 text-sm">
      <a href="/login" class="text-indigo-600 font-semibold hover:underline">Back to login</a>
    </p>
  </div>
  <script>
    const params = new URLSearchParams(window.location.search);
    const qEmail = params.get('email');
    if (qEmail) document.getElementById('email').value = qEmail;

    document.getElementById('verifyForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value.trim().toLowerCase();
      const pin = document.getElementById('pin').value.trim();

      const res = await fetch('/api/auth/verify-admin-pin', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, pin })
      });
      const data = await res.json();
      if (res.ok) {
        alert(data.message);
        window.location.href = '/login';
      } else {
        alert(data.message || 'Verification failed');
      }
    });
  </script>
</body>
</html>
