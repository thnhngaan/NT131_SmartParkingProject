<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Parking Analytics</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    body { font-family: 'Poppins', sans-serif; }
  </style>
</head>

<body class="bg-gradient-to-br from-indigo-100 via-purple-100 to-pink-100 h-screen overflow-hidden">
  <div class="h-screen p-4 md:p-6">
    <div class="h-full max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6">
      <aside class="md:col-span-3 lg:col-span-2 bg-white/80 backdrop-blur rounded-3xl shadow-xl border border-white/60 p-5 flex flex-col">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-800">Smart Parking</h2>
          <p class="text-xs text-gray-500 mt-1">Admin navigation</p>
        </div>
        <nav class="space-y-2">
          <button onclick="window.location.href='/dashboard'" class="w-full text-left px-4 py-3 rounded-xl text-gray-600 bg-gray-50 border border-gray-100 hover:bg-gray-100 transition">
            Dashboard
          </button>
          <button onclick="window.location.href='/analytics'" class="w-full text-left px-4 py-3 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-semibold shadow">
            Analytics
          </button>
        </nav>
        <div class="mt-auto pt-4">
          <button onclick="logout()" class="w-full px-5 py-3 rounded-xl text-white font-semibold bg-gradient-to-r from-gray-800 to-gray-900 hover:from-gray-700 hover:to-black hover:shadow-lg transform hover:-translate-y-0.5 transition duration-300">
            Logout
          </button>
        </div>
      </aside>

<main class="md:col-span-9 lg:col-span-10 bg-white/70 backdrop-blur-md rounded-3xl shadow-xl border border-white/40 p-6 md:p-8 h-full flex flex-col min-h-0 overflow-y-auto">        <div class="mb-6">
          <h1 class="text-3xl md:text-4xl font-bold text-gray-800">Analytics</h1>
          <p id="greetingText" class="text-gray-500 mt-1">Hello, User</p>
        </div>

        <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-6">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-4">
            <h2 class="text-xl font-semibold text-gray-800">Historical Traffic</h2>
            <div class="flex items-center gap-3">
              <label for="historyDate" class="text-sm text-gray-600 font-medium">Select Date</label>
              <input id="historyDate" type="date" class="border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-400">
            </div>
          </div>
          <p id="historyState" class="text-sm text-gray-500 mb-3">Loading historical traffic...</p>
          <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            <div class="h-72">
              <p class="text-sm font-semibold text-emerald-700 mb-2">Vehicle Entries (IN)</p>
              <canvas id="historicalInChart"></canvas>
            </div>
            <div class="h-72">
              <p class="text-sm font-semibold text-rose-700 mb-2">Vehicle Exits (OUT)</p>
              <canvas id="historicalOutChart"></canvas>
            </div>
          </div>
        </section>

        <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
          <div class="flex items-center justify-between gap-4 mb-4">
            <h2 class="text-xl font-semibold text-gray-800">Predicted Traffic (Next 24 Hours)</h2>
            <button id="refreshPredictionBtn" class="text-sm font-semibold px-4 py-2 rounded-lg bg-indigo-50 text-indigo-600 hover:bg-indigo-100 transition">
              Refresh
            </button>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
            <div class="bg-indigo-50 rounded-xl p-4 border border-indigo-100">
              <p class="text-sm text-indigo-700">Max Predicted Entries (IN)</p>
              <p id="maxPrediction" class="text-2xl font-bold text-indigo-900">-</p>
            </div>
            <div class="bg-purple-50 rounded-xl p-4 border border-purple-100">
              <p class="text-sm text-purple-700">Average Predicted Entries (IN)</p>
              <p id="avgPrediction" class="text-2xl font-bold text-purple-900">-</p>
            </div>
            <div class="bg-rose-50 rounded-xl p-4 border border-rose-100">
              <p class="text-sm text-rose-700">Peak Entry Hour (IN)</p>
              <p id="peakHour" class="text-2xl font-bold text-rose-900">-</p>
            </div>
          </div>

          <p id="predictionState" class="text-sm text-gray-500 mb-3">Loading prediction data...</p>
          <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 mb-6">
            <div class="h-72">
              <p class="text-sm font-semibold text-emerald-700 mb-2">Predicted Entries (Next 24h)</p>
              <canvas id="predictionInChart"></canvas>
            </div>
            <div class="h-72">
              <p class="text-sm font-semibold text-rose-700 mb-2">Predicted Exits (Next 24h)</p>
              <canvas id="predictionOutChart"></canvas>
            </div>
          </div>
          <div class="h-80">
            <p class="text-sm font-semibold text-indigo-700 mb-2">Combined IN vs OUT Prediction</p>
            <canvas id="predictionCombinedChart"></canvas>
          </div>
        </section>
      </main>
    </div>
  </div>

  <script>
    let user;
    let historicalInChart;
    let historicalOutChart;
    let predictionInChart;
    let predictionOutChart;
    let predictionCombinedChart;

    const token = localStorage.getItem('token');
    if (!token) window.location.href = '/login';

    function logout() {
      localStorage.removeItem('token');
      window.location.href = '/';
    }

    function formatHourLabel(dateString) {
      return new Date(dateString).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function setText(id, value) {
      document.getElementById(id).textContent = value;
    }

    async function loadUser() {
      const res = await fetch('/api/auth/me', {
        headers: { Authorization: 'Bearer ' + token }
      });
      if (!res.ok) {
        localStorage.removeItem('token');
        window.location.href = '/login';
        return null;
      }
      user = await res.json();
      if (user.role !== 'admin') {
        window.location.href = '/dashboard';
        return null;
      }
      const displayName = user.username || user.name || user.email || 'User';
      setText('greetingText', `Hello, ${displayName}`);
      return user;
    }

    function empty24Hours() {
      return {
        labels: Array.from({ length: 24 }, (_, i) => `${String(i).padStart(2, '0')}:00`),
        inValues: Array.from({ length: 24 }, () => 0),
        outValues: Array.from({ length: 24 }, () => 0)
      };
    }

    function renderSingleFlowChart(canvasId, existingChart, labels, values, label, borderColor, fillColor) {
      const ctx = document.getElementById(canvasId).getContext('2d');
      if (existingChart) existingChart.destroy();
      return new Chart(ctx, {
        type: 'line',
        data: {
          labels,
          datasets: [{
            label,
            data: values,
            borderColor,
            backgroundColor: fillColor,
            fill: true,
            tension: 0.3,
            pointRadius: 3
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: true },
            tooltip: { mode: 'index', intersect: false }
          },
          scales: {
            x: { title: { display: true, text: 'Hour of Day' } },
            y: { beginAtZero: true, title: { display: true, text: 'Vehicles' }, ticks: { precision: 0 } }
          }
        }
      });
    }

    function renderHistoricalCharts(labels, inValues, outValues) {
      historicalInChart = renderSingleFlowChart('historicalInChart', historicalInChart, labels, inValues, 'Vehicle Entries (IN)', '#10b981', 'rgba(16,185,129,0.12)');
      historicalOutChart = renderSingleFlowChart('historicalOutChart', historicalOutChart, labels, outValues, 'Vehicle Exits (OUT)', '#f43f5e', 'rgba(244,63,94,0.12)');
    }

    async function loadHistoricalData(selectedDate) {
      try {
        setText('historyState', 'Loading historical traffic...');
        const res = await fetch(`/api/parking/history?date=${encodeURIComponent(selectedDate)}`, {
          headers: { Authorization: 'Bearer ' + token }
        });

        if (!res.ok) throw new Error('Unable to load historical data');
        const rows = await res.json();
        const base = empty24Hours();
        rows.forEach((row, idx) => {
          if (idx < 24) {
            base.inValues[idx] = Number(row.in) || 0;
            base.outValues[idx] = Number(row.out) || 0;
          }
        });

        renderHistoricalCharts(base.labels, base.inValues, base.outValues);
        const totalIn = base.inValues.reduce((sum, n) => sum + n, 0);
        const totalOut = base.outValues.reduce((sum, n) => sum + n, 0);
        setText('historyState', `Showing historical flow for ${selectedDate} | IN: ${totalIn}, OUT: ${totalOut}`);
      } catch (err) {
        setText('historyState', err.message || 'Failed to load historical traffic.');
        const base = empty24Hours();
        renderHistoricalCharts(base.labels, base.inValues, base.outValues);
      }
    }

    function renderPredictionCharts(data) {
      const labels = data.map((d) => formatHourLabel(d.ds));
      const inValues = data.map((d) => Number(d.in) || 0);
      const outValues = data.map((d) => Number(d.out) || 0);
      const inMaxVal = Math.max(...inValues, 0);

      predictionInChart = renderSingleFlowChart('predictionInChart', predictionInChart, labels, inValues, 'Predicted Entries (IN)', '#10b981', 'rgba(16,185,129,0.12)');
      predictionOutChart = renderSingleFlowChart('predictionOutChart', predictionOutChart, labels, outValues, 'Predicted Exits (OUT)', '#f43f5e', 'rgba(244,63,94,0.12)');

      const ctx = document.getElementById('predictionCombinedChart').getContext('2d');
      if (predictionCombinedChart) predictionCombinedChart.destroy();

      predictionCombinedChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels,
          datasets: [
            {
              label: 'Predicted Entries (IN)',
              data: inValues,
              borderColor: '#10b981',
              backgroundColor: 'rgba(16,185,129,0.1)',
              fill: false,
              tension: 0.3,
              pointRadius: inValues.map((v) => (v === inMaxVal ? 5 : 3)),
              pointBackgroundColor: inValues.map((v) => (v === inMaxVal ? '#065f46' : '#10b981'))
            },
            {
              label: 'Predicted Exits (OUT)',
              data: outValues,
              borderColor: '#f43f5e',
              backgroundColor: 'rgba(244,63,94,0.1)',
              fill: false,
              tension: 0.3,
              pointRadius: 3
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: true },
            tooltip: { mode: 'index', intersect: false }
          },
          scales: {
            x: { title: { display: true, text: 'Time' } },
            y: { beginAtZero: true, title: { display: true, text: 'Predicted Vehicles' }, ticks: { precision: 0 } }
          }
        }
      });
    }

    function updatePredictionStats(data) {
      if (!data.length) {
        setText('maxPrediction', '-');
        setText('avgPrediction', '-');
        setText('peakHour', '-');
        return;
      }

      const values = data.map((d) => Number(d.in) || 0);
      const maxValue = Math.max(...values, 0);
      const avgValue = values.length ? (values.reduce((a, b) => a + b, 0) / values.length) : 0;
      const peakIndex = values.indexOf(maxValue);
      const peak = data[peakIndex];

      setText('maxPrediction', maxValue.toFixed(2));
      setText('avgPrediction', avgValue.toFixed(2));
      setText('peakHour', formatHourLabel(peak.ds));
    }

    async function loadPredictionData() {
      try {
        setText('predictionState', 'Loading prediction data...');
        const res = await fetch('http://127.0.0.1:5000/predict');
        if (!res.ok) throw new Error('Prediction service unavailable');
        const data = await res.json();
        if (!Array.isArray(data)) throw new Error('Invalid prediction response format');
        const valid = data.every((item) => item && item.ds !== undefined && item.in !== undefined && item.out !== undefined);
        if (!valid) throw new Error('Prediction response missing IN/OUT fields');

        renderPredictionCharts(data);
        updatePredictionStats(data);
        setText('predictionState', 'Prediction loaded successfully.');
      } catch (err) {
        setText('predictionState', `${err.message || 'Failed to load prediction data.'} Make sure Flask AI service is running on port 5000.`);
        renderPredictionCharts([]);
        updatePredictionStats([]);
      }
    }

    document.getElementById('refreshPredictionBtn').addEventListener('click', loadPredictionData);

    const dateInput = document.getElementById('historyDate');
    const today = new Date();
    const yyyy = today.getFullYear();
    const mm = String(today.getMonth() + 1).padStart(2, '0');
    const dd = String(today.getDate()).padStart(2, '0');
    const todayValue = `${yyyy}-${mm}-${dd}`;
    dateInput.value = todayValue;

    dateInput.addEventListener('change', () => {
      loadHistoricalData(dateInput.value);
    });

    loadUser().then((u) => {
      if (!u) return;
      return Promise.all([loadHistoricalData(todayValue), loadPredictionData()]);
    });
  </script>
</body>
</html>
